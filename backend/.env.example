# =========================================================================
# PCOS TRACKER ENVIRONMENT VARIABLES TEMPLATE
# Copy this file to '.env' inside the 'backend/' folder and populate your secrets.
# =========================================================================

# JWT Security
SECRET_KEY=supersecretkeyforpcostrackingapp12345!

# Database Configuration (leave commented to fallback to SQLite automatically)
# DATABASE_URL=postgresql://user:password@localhost:5432/pcos_db

# Discord Webhook Alerts Configuration
# Create a webhook in your Discord Server (Server Settings -> Integrations -> Webhooks)
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your_webhook_id/your_webhook_token

# Email Alerts Configuration (Gmail SMTP example)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_gmail_app_password
MAIL_FROM=reminders@pcostracker.org
